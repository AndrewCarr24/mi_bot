# DeepSeek (orchestrator default)
DEEPSEEK_API_KEY=

# AWS — used for Bedrock embeddings (Titan v2) at KB build time, and for
# the router/judge models (Haiku) at runtime regardless of orchestrator
# provider. Make sure your local AWS credentials chain (env, profile, or
# instance role) can reach these regions.
AWS_REGION=us-east-1

# Optional overrides
# ORCHESTRATOR_PROVIDER=deepseek          # deepseek | bedrock
# ORCHESTRATOR_MODEL_ID=us.anthropic.claude-sonnet-4-6   # only when provider=bedrock
# DEEPSEEK_MODEL_ID=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# ROUTER_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# AgentCore Memory — leave unset to run stateless across requests
# MEMORY_ID=
